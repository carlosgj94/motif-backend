APP_BIND_ADDR=0.0.0.0:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001,http://0.0.0.0:3000,http://0.0.0.0:3001
DB_MAX_CONNECTIONS=10
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<your-supabase-publishable-or-anon-key>
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWKS_CACHE_TTL_SECONDS=300
CONTENT_PROCESSING_MAX_REDIRECTS=5
CONTENT_PROCESSING_MAX_HTML_BYTES=2097152
CONTENT_PROCESSING_MAX_OEMBED_BYTES=131072
CONTENT_PROCESSING_MAX_PARSED_BLOCKS=128
CONTENT_PROCESSING_MAX_TEXT_CHARS=4000
CONTENT_PROCESSING_MAX_CODE_CHARS=16000
CONTENT_PROCESSING_MAX_LIST_ITEMS=50
CONTENT_PROCESSING_MAX_LIST_ITEM_CHARS=500
CONTENT_PROCESSING_MAX_PARSED_DOCUMENT_BYTES=262144
